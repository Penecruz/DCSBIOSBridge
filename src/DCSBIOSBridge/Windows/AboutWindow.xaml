<Window x:Class="DCSBIOSBridge.Windows.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="About DCS-BIOS Bridge" Height="650" Width="700" Loaded="WindowLoaded" Icon="/images/app_image.jpg" MinHeight="450" MinWidth="600">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="8">
                <Image Name="ImageSchema" Source="/images/broker_schema.png" Tag="False" MinWidth="450" MaxWidth="640" RenderOptions.BitmapScalingMode="Fant" IsEnabled="False" Stretch="Uniform" Margin="0,0,0,12" />

                <TextBlock FontWeight="Bold" FontSize="18" Margin="0,0,0,8">DCS-BIOS Bridge</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,12">
                    This bridge forwards and manages DCS-BIOS serial traffic between DCS and your connected hardware devices.
                </TextBlock>

                <Separator Margin="0,0,0,10" />

                <TextBlock FontWeight="Bold" FontSize="16" Margin="0,0,0,8">Settings Notes</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">• DCS-BIOS network settings control UDP endpoints used to receive cockpit data from DCS-BIOS and send output commands back to your devices.</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">• Delay between DCS-BIOS commands smooths command bursts and can improve reliability on slower USB/serial adapters (value must be greater than 0).</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">• Open all ports on startup is useful for fixed cockpit setups where all known ports should reconnect automatically when the app starts.</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">• Enable Watch Dog turns automatic serial recovery on or off globally. Disable it for troubleshooting or when you want manual-only recovery.</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">• Watch Dog no-read timeout + recent-write window detect stalled devices: if writes are still happening but reads stop, the watchdog barks and reopens the port.</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">• Cooldown and reopen delay prevent aggressive loop-restarts. Higher values are safer for unstable hardware; lower values recover faster.</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,12">• For dropped ports, the bridge can re-add the COM device and retry opening it after timed delays (helpful for USB brown-outs and intermittent device resets).</TextBlock>

                <Separator Margin="0,0,0,10" />

                <TextBlock FontWeight="Bold" FontSize="16" Margin="0,0,0,8">Latest Changelog (v1.2.2)</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">• Version 1.2.2 released.</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">• Added global Enable Watch Dog setting to quickly toggle watchdog recovery behavior.</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">• Improved dropped-port recovery by scheduling COM re-add scans when serial errors are detected.</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">• Added restored-port open retry flow with delayed attempts for better brown-out recovery.</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,12">• Expanded watchdog and recovery logging to make intermittent COM issues easier to diagnose.</TextBlock>

                <Separator Margin="0,0,0,10" />

                <TextBlock FontWeight="Bold" FontSize="16" Margin="0,0,0,8">Contributors</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,4">From DCS-Skunkworks:</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,4">• jdahlblom</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,4">• charliefoxtwo</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,6">• Mutex666</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,12">• Penecruz</TextBlock>

                <TextBlock TextWrapping="Wrap" Margin="0,0,0,4">More information:</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                    <Hyperlink RequestNavigate="HyperlinkRequestNavigate" NavigateUri="https://github.com/DCS-Skunkworks/DCSBIOSBridge/wiki">DCS-BIOS Bridge Wiki</Hyperlink>
                </TextBlock>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Name="ButtonOk" Content="Ok" Width="80" Click="ButtonOk_OnClick" />
        </StackPanel>
    </Grid>
</Window>
